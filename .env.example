# GitHub authentication
# Option 1: direct token/PAT. This takes precedence when set.
GITHUB_TOKEN=ghp_replace_me

# Option 2: GitHub App authentication. Used only when GITHUB_TOKEN is empty.
# Provide either GITHUB_APP_PRIVATE_KEY or GITHUB_APP_PRIVATE_KEY_FILE.
# If storing the PEM key as a single-line CI secret, literal \n sequences are supported.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_FILE=

# GitHub Project configuration
GITHUB_PROJECT_OWNER=octo-org
GITHUB_PROJECT_NUMBER=5

# "organization" or "user"
GITHUB_PROJECT_OWNER_TYPE=organization

# Digest assignee. Use @me for the authenticated token owner, a GitHub login,
# or username:email@example.com to send that user's digest by email.
# The ordinary shell USER variable is intentionally ignored.
GITHUB_USER=@me

# Optional
# @user and @me in this filter resolve to the configured GITHUB_USER value.
GITHUB_PROJECT_FILTER=sprint:@current assignee:@user is:issue state:open
DIGEST_TEMPLATE_TEXT=digest.txt.j2
DIGEST_TEMPLATE_HTML=digest.html.j2
DIGEST_OUTPUT_FORMAT=text
# OUTPUT_FORMAT is also supported as a compatibility alias for DIGEST_OUTPUT_FORMAT.
GITHUB_PROJECT_PAGE_SIZE=50
GITHUB_PROJECT_FIELD_VALUE_LIMIT=50

# Optional SMTP delivery. Email is sent only when GITHUB_USER includes an email address,
# such as GITHUB_USER=octocat:octocat@example.com. For Gmail, use an app password,
# not your normal account password.
SMTP_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_SUBJECT=GitHub Project Digest
SMTP_TIMEOUT=30
