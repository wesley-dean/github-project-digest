<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ project.title }}</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f6f8fa; color:#24292f; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; font-size:14px; line-height:1.5;">
    <div style="max-width:760px; margin:0 auto; padding:24px 16px;">
      <div style="background-color:#ffffff; border:1px solid #d0d7de; border-radius:8px; overflow:hidden;">
        <div style="padding:20px 24px; border-bottom:1px solid #d0d7de;">
          <h1 style="margin:0 0 8px 0; font-size:22px; line-height:1.25; color:#24292f;">{{ project.title }}</h1>
          <p style="margin:0; color:#57606a;"><a href="{{ project.url }}" style="color:#0969da; text-decoration:none;">Project board</a></p>
        </div>

        <div style="padding:16px 24px; border-bottom:1px solid #d0d7de; background-color:#f6f8fa;">
          <p style="margin:0 0 8px 0; color:#57606a;">Assignee: <strong style="color:#24292f;">{{ assignee.login }}</strong>{% if requested_user != assignee.login %} <span style="color:#57606a;">(requested: {{ requested_user }})</span>{% endif %}</p>
          <p style="margin:0 0 8px 0; color:#57606a;">Issues matching: <code style="font-family:ui-monospace, SFMono-Regular, Consolas, 'Liberation Mono', Menlo, monospace; font-size:12px; background-color:#eaeef2; border-radius:4px; padding:2px 5px; color:#24292f;">{{ filter_query }}</code></p>
          <p style="margin:0; color:#24292f;">
            <strong>{{ summary.total }}</strong> issue{{ '' if summary.total == 1 else 's' }}
            {% if summary.due_today %} &bull; <strong style="color:#cf222e;">{{ summary.due_today }} due today</strong>{% endif %}
            {% if summary.overdue %} &bull; <strong style="color:#bc4c00;">{{ summary.overdue }} overdue</strong>{% endif %}
            &bull; {{ summary.with_due_date }} with due dates
            &bull; {{ summary.without_due_date }} unscheduled
          </p>
        </div>

        <div style="padding:8px 24px 24px 24px;">
          {% if count %}
            {% for section in sections if section.issues %}
            <div style="margin-top:20px;">
              <h2 style="margin:0 0 10px 0; font-size:17px; line-height:1.3; color:#24292f;">{{ section.title }} <span style="font-size:13px; color:#57606a; font-weight:400;">({{ section.count }})</span></h2>
              <ul style="margin:0; padding:0; list-style:none;">
                {% for issue in section.issues %}
                <li style="margin:0 0 10px 0; padding:12px; border:1px solid #d0d7de; border-radius:6px; background-color:#ffffff;">
                  <div style="font-size:15px; line-height:1.4; color:#24292f;">
                    <span style="display:inline-block; width:1.6em;">{{ issue.due_marker }}</span>
                    {% if issue.issue_ref %}<span style="color:#57606a; font-size:13px;">{{ issue.issue_ref }}</span> {% endif %}
                    <a href="{{ issue.url }}" style="color:#0969da; text-decoration:none; font-weight:600;">{{ issue.title }}</a>
                  </div>
                  <div style="margin-top:6px; font-size:13px; color:#57606a;">
                    {% if issue.repository %}<span>{{ issue.repository }}</span><span>&nbsp;&bull;&nbsp;</span>{% endif %}<span>{% if issue.assignees %}{% for issue_assignee in issue.assignees %}{% if not loop.first %}, {% endif %}{% if issue_assignee == assignee.login %}<strong style="color:#24292f;">{{ issue_assignee }}</strong>{% else %}{{ issue_assignee }}{% endif %}{% endfor %}{% else %}unassigned{% endif %}</span>{% if issue.due_date %}<span>&nbsp;&bull;&nbsp;</span><span style="{% if issue.due_state == 'overdue' %}color:#bc4c00; font-weight:600;{% elif issue.due_state == 'today' %}color:#cf222e; font-weight:600;{% elif issue.due_state == 'soon' %}color:#9a6700; font-weight:600;{% elif issue.due_state == 'upcoming' %}color:#0969da; font-weight:600;{% elif issue.due_state == 'later' %}color:#57606a; font-weight:600;{% endif %}">due: {{ issue.due_date }}</span>{% endif %}
                  </div>
                </li>
                {% endfor %}
              </ul>
            </div>
            {% endfor %}
          {% else %}
          <p style="margin:16px 0 0 0; color:#57606a;">No matching issues found.</p>
          {% endif %}
        </div>
      </div>
    </div>
  </body>
</html>
